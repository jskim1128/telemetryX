# ============================================================================
# DATABASE_URL
# ============================================================================
# The app targets PostgreSQL for both local development and production.
# The Prisma schema lives at prisma/schema.prisma and migrations under
# prisma/migrations/.
#
# Local development options:
#   - Start a local Postgres via docker-compose:
#       docker-compose up -d postgres
#     and use the local URL below.
#   - Or point directly at the shared production instance (use with care).
#
# In production, DATABASE_URL is injected from k8s/20-app-secret.yaml.

# Local Docker Postgres (from docker-compose.yml):
DATABASE_URL="postgresql://feat:featpass@localhost:5432/feattracking?schema=public"

# Shared production Postgres (10.91.26.224) — use only if you know what you're doing:
# DATABASE_URL="postgresql://postgres:sandisk-telemetryx@10.91.26.224:5432/postgres?schema=public"

# ============================================================================
# JWT_SECRET
# ============================================================================
# Secret used to sign the 30-day session cookie. Must be at least 32 random
# characters in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# ============================================================================
# COOKIE_SECURE (optional)
# ============================================================================
# Controls the `Secure` attribute on the session cookie.
#   - Set to "true" ONLY when the app is served over HTTPS (e.g. behind the
#     k8s ingress in production). The k8s ConfigMap sets this for you.
#   - Leave unset (or "false") for local development and for plain `docker run`
#     / `docker-compose up` on http://localhost:3000. Browsers silently drop
#     `Secure` cookies on non-HTTPS origins, which would make login appear to
#     succeed but immediately bounce the user back to the login page.
# COOKIE_SECURE="false"

# ============================================================================
# AUTH_ASMX_BASE_URL (optional)
# ============================================================================
# Base URL of the corporate AD ASMX endpoint used for authentication and
# profile lookup. Defaults to the production AD service when unset.
# AUTH_ASMX_BASE_URL="http://sdsmsipiccsvip.ad.shared/adauth/service1.asmx"
