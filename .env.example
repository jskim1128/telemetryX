# ============================================================================
# DATABASE_URL
# ============================================================================
# This project ships with TWO Prisma schemas so dev and prod use different
# databases without needing manual edits:
#
#   - LOCAL DEV  (`npm run dev`)   → SQLite, schema: prisma/schema.prisma
#                                    file at ./prisma/dev.db (zero-config)
#   - PRODUCTION (Docker / K8s)    → PostgreSQL, schema: prisma/schema.postgres.prisma
#                                    URL injected from k8s/20-app-secret.yaml
#
# For local development, leave this as the SQLite file URL:
DATABASE_URL="file:./dev.db"

# To test the production (Postgres) path locally — e.g. point at a local
# Docker Postgres or a port-forwarded in-cluster Postgres — set:
# DATABASE_URL="postgresql://feat:featpass@localhost:5432/feattracking?schema=public"
# and run the *:prod variants of the scripts:
#   npm run prisma:generate:prod
#   npm run prisma:migrate:prod   # for schema changes
#   npm run prisma:deploy:prod    # for applying existing migrations

# ============================================================================
# JWT_SECRET
# ============================================================================
# Secret used to sign the 30-day session cookie. Must be at least 32 random
# characters in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# ============================================================================
# AUTH_ASMX_BASE_URL (optional)
# ============================================================================
# Base URL of the corporate AD ASMX endpoint used for authentication and
# profile lookup. Defaults to the production AD service when unset.
# AUTH_ASMX_BASE_URL="http://sdsmsipiccsvip.ad.shared/adauth/service1.asmx"
