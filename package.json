{
  "name": "telemetryx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "next:build": "next build",
    "build": "prisma generate && next build",
    "build:prod": "prisma generate --schema=prisma/schema.postgres.prisma && next build",
    "start": "next start",
    "format": "prettier --write \"{app,layout,lib,types}/**/*.{js,ts,tsx,d.ts}\"",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema=prisma/schema.postgres.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate dev --schema=prisma/schema.postgres.prisma",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy:prod": "prisma migrate deploy --schema=prisma/schema.postgres.prisma",
    "prisma:studio": "prisma studio",
    "prisma:studio:prod": "prisma studio --schema=prisma/schema.postgres.prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.18.0",
    "@types/node": "20.3.1",
    "@types/react": "18.2.12",
    "@types/react-dom": "18.2.5",
    "chart.js": "4.2.1",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "primeflex": "^3.3.1",
    "primeicons": "^6.0.1",
    "primereact": "10.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-transition-group": "^4.4.5",
    "telemetryx": "link:",
    "typescript": "5.1.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/react-transition-group": "^4.4.12",
    "@types/xml2js": "^0.4.14",
    "eslint": "8.43.0",
    "eslint-config-next": "13.5.6",
    "prettier": "^2.8.8",
    "prisma": "5.18.0",
    "sass": "^1.101.0"
  }
}
