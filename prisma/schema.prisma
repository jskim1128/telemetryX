// Prisma schema for the Feature Tracking app — PostgreSQL (default).
//
// This is the single source of truth for both local development and
// production. The app targets PostgreSQL; the connection string is read
// from the DATABASE_URL environment variable (see .env / .env.example).
//
// Migrations live in `prisma/migrations/` and are applied with the
// standard Prisma commands (`prisma migrate dev`, `prisma migrate deploy`).
//
// Note: `metadata` is stored as a String (text) — callers send JSON
// objects which the API serializes to a string before writing. This
// kept parity with the previous SQLite schema and avoids a breaking
// change to the on-the-wire payload format.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  employeeId  String?  @unique
  email       String   @unique
  displayName String?
  title       String?
  // Role for RBAC. "admin" can manage everything; "user" is a regular
  // authenticated user. First user to register is auto-promoted to admin.
  role        String   @default("user")
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

model App {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  // Hash of the plaintext API key (sha256, hex). Plaintext is never stored.
  apiKeyHash   String   @unique
  // First 12 chars of the plaintext key — used to visually identify the key.
  apiKeyPrefix String
  ownerEmail   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appOpens AppOpenEvent[]
  features FeatureEvent[]
  tags     TagEvent[]

  @@index([name])
  @@index([active])
}

model AppOpenEvent {
  id         String   @id @default(cuid())
  appId      String
  email      String
  department String?
  sessionId  String?
  metadata   String?
  createdAt  DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, createdAt])
  @@index([appId, email])
  @@index([department])
  @@index([createdAt])
}

model FeatureEvent {
  id          String   @id @default(cuid())
  appId       String
  featureName String
  email       String
  department  String?
  metadata    String?
  createdAt   DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, featureName, createdAt])
  @@index([appId, email])
  @@index([department])
  @@index([createdAt])
}

model TagEvent {
  id         String   @id @default(cuid())
  appId      String
  tag        String
  email      String
  department String?
  metadata   String?
  createdAt  DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, tag, createdAt])
  @@index([appId, email])
  @@index([department])
  @@index([createdAt])
}
